# All Target
all: 
	$(MAKE) --no-print-directory main-build 

main-build: HOST_KM_BRIDGE.elf secondary-outputs

# Tool invocations
HOST_KM_BRIDGE.elf: $(OBJS) $(USER_OBJS_ESCAPE)
	@	riscv-none-embed-gcc -march=rv32imacxw -mabi=ilp32 -msmall-data-limit=8 -msave-restore -fmax-errors=20 -Os -fmessage-length=0 -fsigned-char -ffunction-sections -fdata-sections -fno-common -Wunused -Wuninitialized -Wextra -g -T "d:\git_hl\USB\HOST_KM_BRIDGE\Ld\Link.ld" -nostartfiles -Xlinker --gc-sections -Wl,-Map,"HOST_KM_BRIDGE.map" --specs=nano.specs --specs=nosys.specs -o "HOST_KM_BRIDGE.elf" $(OBJS) $(LIBS)
HOST_KM_BRIDGE.hex: HOST_KM_BRIDGE.elf
	@	riscv-none-embed-objcopy -O ihex "HOST_KM_BRIDGE.elf" "HOST_KM_BRIDGE.hex"
HOST_KM_BRIDGE.lst: HOST_KM_BRIDGE.elf
	@	riscv-none-embed-objdump --all-headers --demangle --disassemble -M xw "HOST_KM_BRIDGE.elf" > "HOST_KM_BRIDGE.lst"
HOST_KM_BRIDGE.siz: HOST_KM_BRIDGE.elf
	riscv-none-embed-size --format=berkeley "HOST_KM_BRIDGE.elf"

# Other Targets
clean:
	-$(RM) $(DIR_OBJS) $(SECONDARY_FLASH)$(SECONDARY_LIST)$(SECONDARY_SIZE) HOST_KM_BRIDGE.elf
	-$(RM) $(DIR_EXPANDS) $(CALLGRAPH_DOT)
	-$(RM) $(DIR_DEPS)
secondary-outputs: $(SECONDARY_FLASH) $(SECONDARY_LIST) $(SECONDARY_SIZE)

